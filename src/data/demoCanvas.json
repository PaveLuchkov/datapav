          { "id": "attr-cc-3", "name": "country",       "type": "string" },
          { "id": "attr-cc-4", "name": "segment",       "type": "string" }
        ]
      }
    },

    {
      "id": "node-merge",
      "type": "mergeNode",
      "position": { "x": 1680, "y": 360 },
      "data": {
        "label": "enrich_orders",
        "joinType": "left",
        "keyPairs": [{ "left": "customer_id", "right": "customer_id" }],
        "stage": null,
        "code": "",
        "companionId": "df-merged"
      }
    },

    {
      "id": "df-merged",
      "type": "dataFrameNode",
      "position": { "x": 2020, "y": 360 },
      "data": {
        "_companionOf": "node-merge",
        "label": "orders_enriched",
        "stage": null,
        "code": "",
        "attributes": [
          { "id": "attr-me-1", "name": "order_id",      "type": "string" },
          { "id": "attr-me-2", "name": "customer_id",   "type": "string" },
          { "id": "attr-me-3", "name": "amount",        "type": "float"  },
          { "id": "attr-me-4", "name": "order_date",    "type": "string" },
          { "id": "attr-me-5", "name": "customer_name", "type": "string" },
          { "id": "attr-me-6", "name": "country",       "type": "string" },
          { "id": "attr-me-7", "name": "segment",       "type": "string" }
        ]
      }
    },

    {
      "id": "node-groupby",
      "type": "groupByNode",
      "position": { "x": 2360, "y": 150 },
      "data": {
        "label": "revenue_by_segment",
        "stage": null,
        "code": "",
        "inputs": [
          { "id": "gb-inp-1", "attrName": "country",   "attrType": "string", "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-6" },
          { "id": "gb-inp-2", "attrName": "segment",   "attrType": "string", "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-7" },
          { "id": "gb-inp-3", "attrName": "amount",    "attrType": "float",  "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-3" },
          { "id": "gb-inp-4", "attrName": "order_id",  "attrType": "string", "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-1" }
        ],
        "groupByInputIds": ["gb-inp-1", "gb-inp-2"],
        "aggregations": [
          { "id": "agg-1", "inputId": "gb-inp-3", "func": "sum",   "outputName": "total_revenue" },
          { "id": "agg-2", "inputId": "gb-inp-4", "func": "count", "outputName": "order_count"   }
        ],
        "companionId": "df-revenue"
      }
    },

    {
      "id": "df-revenue",
      "type": "dataFrameNode",
      "position": { "x": 2780, "y": 150 },
      "data": {
        "_companionOf": "node-groupby",
        "label": "revenue_summary",
        "stage": "final",
        "code": "",
        "attributes": [
          { "id": "attr-rs-1", "name": "country",       "type": "string" },
          { "id": "attr-rs-2", "name": "segment",       "type": "string" },
          { "id": "attr-rs-3", "name": "total_revenue", "type": "float"  },
          { "id": "attr-rs-4", "name": "order_count",   "type": "int"    }
        ]
      }
    },

    {
      "id": "node-function",
      "type": "functionNode",
      "position": { "x": 2360, "y": 590 },
      "data": {
        "label": "compute_ltv",
        "stage": null,
        "code": "def compute_ltv(amount, segment):\n    multipliers = {'premium': 3.0, 'standard': 1.5, 'basic': 1.0}\n    m = multipliers.get(segment, 1.0)\n    ltv_score = round(amount * m, 2)\n    tier = 'gold' if ltv_score > 500 else 'silver' if ltv_score > 100 else 'bronze'\n    return ltv_score, tier",
        "inputs": [
          { "id": "fn-inp-1", "attrName": "amount",  "attrType": "float",  "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-3" },
          { "id": "fn-inp-2", "attrName": "segment", "attrType": "string", "sourceNodeId": "df-merged", "sourceNodeLabel": "orders_enriched", "sourceAttrId": "attr-me-7" }
        ],
        "outputs": [
          { "id": "fn-out-1", "name": "ltv_score",     "type": "float",  "fromInputId": "fn-inp-1" },
          { "id": "fn-out-2", "name": "customer_tier", "type": "string"                             }
        ],
        "companionId": "df-ltv"
      }
    },

    {
      "id": "df-ltv",
      "type": "dataFrameNode",
      "position": { "x": 2780, "y": 590 },
      "data": {
        "_companionOf": "node-function",
        "label": "customer_ltv",
        "stage": "final",
        "code": "",
        "attributes": [
          { "id": "attr-ltv-1", "name": "ltv_score",     "type": "float"  },
          { "id": "attr-ltv-2", "name": "customer_tier", "type": "string" }
        ]
      }
    }

