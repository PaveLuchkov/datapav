{
  "nodes": [

    {
      "id": "cmt-intro",
      "type": "commentNode",
      "position": { "x": 60, "y": -160 },
      "data": {
        "color": "blue",
        "text": "👋 Welcome to Lineage Editor!\n\nThis demo shows an e-commerce order pipeline.\n\n→ Click ◎ on any column to trace its lineage\n→ Double-click any label to rename it\n→ Drag columns between DataFrames\n→ Cmd+K to search columns across the graph\n→ Use →○ buttons to create output DataFrames"
      }
    },

    {
      "id": "cmt-analysis",
      "type": "commentNode",
      "position": { "x": 2020, "y": -160 },
      "data": {
        "color": "green",
        "text": "🔀 Two analysis paths from the enriched table:\n\n1. GroupBy → revenue aggregated by country & segment\n2. Function → custom LTV score per order\n\nCompanion DFs (marked ⊙) are auto-managed — their columns update when the operator changes."
      }
    },

    {
      "id": "df-orders",
      "type": "dataFrameNode",
      "position": { "x": 60, "y": 180 },
      "data": {
        "label": "orders_raw",
        "stage": "raw",
        "code": "",
        "attributes": [
          { "id": "attr-o-1", "name": "order_id",    "type": "string" },
          { "id": "attr-o-2", "name": "customer_id", "type": "string" },
          { "id": "attr-o-3", "name": "amount",      "type": "string" },
          { "id": "attr-o-4", "name": "status",      "type": "string" },
          { "id": "attr-o-5", "name": "order_date",  "type": "string" }
        ]
      }
    },

    {
      "id": "df-customers",
      "type": "dataFrameNode",
      "position": { "x": 60, "y": 570 },
      "data": {
        "label": "customers",
        "stage": "raw",
        "code": "",
        "attributes": [
          { "id": "attr-c-1", "name": "customer_id", "type": "string" },
          { "id": "attr-c-2", "name": "name",        "type": "string" },
          { "id": "attr-c-3", "name": "country",     "type": "string" },
          { "id": "attr-c-4", "name": "segment",     "type": "string" }
        ]
      }
    },

    {
      "id": "node-filter",
      "type": "filterNode",
      "position": { "x": 390, "y": 180 },
      "data": {
        "label": "completed_only",
        "stage": null,
        "code": "",
        "conditions": [
          { "id": "cond-1", "op": "WHERE", "expr": "status == 'completed'" }
        ],
        "companionId": "df-filtered"
      }
    },

    {
      "id": "df-filtered",
      "type": "dataFrameNode",
      "position": { "x": 710, "y": 180 },
      "data": {
        "_companionOf": "node-filter",
        "label": "orders_filtered",
        "stage": null,
        "code": "",
        "attributes": [
          { "id": "attr-of-1", "name": "order_id",    "type": "string" },
          { "id": "attr-of-2", "name": "customer_id", "type": "string" },
          { "id": "attr-of-3", "name": "amount",      "type": "string" },
          { "id": "attr-of-4", "name": "status",      "type": "string" },
          { "id": "attr-of-5", "name": "order_date",  "type": "string" }
        ]
      }
    },

    {
      "id": "node-transform",
      "type": "transformNode",
      "position": { "x": 1020, "y": 180 },
      "data": {
        "label": "clean_orders",
        "stage": null,
        "code": "# amount was imported as string — cast to float\n# fill missing dates, drop status (already filtered)",
        "ops": [
          { "id": "op-1", "type": "astype",          "args": { "col": "amount",     "type_val": "float"  } },
          { "id": "op-2", "type": "fillna",           "args": { "col": "order_date", "value":    "2024-01-01" } },
          { "id": "op-3", "type": "drop_column",      "args": { "col": "status"     } },
          { "id": "op-4", "type": "drop_duplicates",  "args": {}                      }
        ],
        "companionId": "df-clean"
      }
    },

    {
      "id": "df-clean",
      "type": "dataFrameNode",
      "position": { "x": 1360, "y": 180 },
      "data": {
        "_companionOf": "node-transform",
        "label": "orders_clean",
        "stage": null,
        "code": "",
        "attributes": [
          { "id": "attr-oc-1", "name": "order_id",    "type": "string" },
          { "id": "attr-oc-2", "name": "customer_id", "type": "string" },
